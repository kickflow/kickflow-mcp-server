{
  "name": "@kickflow/mcp-server",
  "version": "1.0.7",
  "description": "MCP Server for kickflow API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "@kickflow/mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "url": "https://github.com/kickflow/kickflow-mcp-server"
  },
  "scripts": {
    "build": "vp build",
    "dev": "vp exec tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vp test",
    "test:watch": "vp test watch",
    "test:inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "update-schema": "curl -s https://developer.kickflow.com/rest/schema.yaml -o schema.yaml",
    "generate-api": "rm -rf ./src/kickflow-api/generated && orval --config orval.config.ts && vp fmt",
    "lint": "vp lint",
    "format": "vp fmt",
    "prepare": "vp config"
  },
  "keywords": [
    "kickflow",
    "api",
    "mcp",
    "server"
  ],
  "author": "kickflow, Inc.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "axios": "1.13.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "axios-mock-adapter": "2.1.0",
    "orval": "8.5.2",
    "tsx": "4.21.0",
    "yaml": "2.8.2",
    "vite-plus": "0.1.14"
  },
  "packageManager": "npm@11.12.1"
}
